#!/usr/bin/env bash
# Convenience wrapper — runs tgcli with the project's venv Python.
# Usage from the repo root:
#   ./tg contacts --limit 200
#   ./tg backfill --download-media
#   ./tg listen --notify --download-media
HERE="$(cd "$(dirname "$0")" && pwd)"
exec "$HERE/.venv/bin/python" -m tgcli "$@"
